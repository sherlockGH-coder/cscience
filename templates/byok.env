# Claude Science BYOK Configuration
# Location: ~/.claude-science/byok.env

# --- Required (pick one) ---

# Anthropic API Key
ANTHROPIC_API_KEY=

# Or OAuth Bearer Token
# ANTHROPIC_AUTH_TOKEN=

# --- Optional ---

# Custom API endpoint (default: https://api.anthropic.com)
# Supports Anthropic Messages, OpenAI Chat Completions, and OpenAI Responses.
# Example DeepSeek Anthropic path (model list is auto-discovered):
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_BASE_URL=

# Custom model list (skip models.list API call; highest priority)
# Format: id:DisplayName,id:DisplayName
# Or JSON: [{"id":"model-id","name":"Display Name"}]
# OPERON_MODELS=claude-sonnet-4-6:Sonnet 4.6,claude-opus-4-8:Opus 4.8

# Server port (default: 8000)
# PORT=8000

# Skip auto-update check
# NO_AUTO_UPDATE=1

# --- Advanced troubleshooting (leave empty unless auto-detection fails) ---

# Force inference API format: auto | anthropic | openai-chat | openai-responses
# BYOK_API_FORMAT=auto

# Explicit models list URL when auto discovery fails
# BYOK_MODELS_URL=

# Force provider capability rules: auto | deepseek | generic
# BYOK_PROVIDER=auto

# DeepSeek thinking effort when enabled: high | max
# BYOK_REASONING_EFFORT=high

# Redacted probe logs (never prints secrets or prompt bodies): 0 | 1
# BYOK_DEBUG=0

# Maintainer-only emergency switch: disable local BYOK adapter and use direct
# Anthropic credentials in Claude Science. Do not enable for OpenAI/DeepSeek.
# BYOK_ADAPTER=1
