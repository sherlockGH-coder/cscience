{
  "name": "claude-science-byok",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build":           "node scripts/build.mjs",
    "build:mac-arm64": "node scripts/build.mjs --platform mac-arm64",
    "build:mac-x64":   "node scripts/build.mjs --platform mac-x64",
    "build:linux-x64": "node scripts/build.mjs --platform linux-x64",
    "build:all":       "node scripts/build.mjs --platform all",
    "test":            "node --test 'test/unit/**/*.test.mjs' 'test/integration/**/*.test.mjs'",
    "test:e2e:mock":   "node --test 'test/e2e/**/*.test.mjs'",
    "test:all":        "npm test && npm run test:e2e:mock"
  },
  "devDependencies": {
    "acorn": "^8.16.0",
    "node-lief": "^1.3.0"
  }
}
